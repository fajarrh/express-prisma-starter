NODE_ENV=development

APP_URL="http://localhost:3000"
PORT=3000

DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=
DB_SCHEMA=public
DATABASE_URL="postgresql://postgres:_PASSWORD_@localhost:5432/_DATABASE_?schema=public"

JWT_SECRET=12345

REDIS_PORT=6379
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=

CORS_ORIGIN=*
CORS_CREDENTIALS=true
CORS_ALLOW_METHODS="GET,POST,PUT,DELETE,PATCH"
CORS_ALLOW_HEADERS="Origin,Authorization,Content-Type,Accept,TimeZoneOffset,TimeZone"